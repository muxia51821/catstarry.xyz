---
import Layout from '../../../layouts/Base.astro';
import { getCategoryLabel } from '../../../lib/category';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params as { category: string };
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === category))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const label = getCategoryLabel(category);
---

<Layout title={`${label} — 博客`} description={`${label}分类下的所有文章。`}>
  <main class="blog-content" style="max-width: var(--content-width); margin: 2rem auto; padding: 0 var(--content-padding);">
    <h1>分类：{label}</h1>
    <p><a href="/blog/" class="back-link">← 返回博客列表</a></p>

    <div class="post-list" style="margin-top: var(--space-lg);">
      {posts.length === 0 ? (
        <p>该分类下还没有文章。</p>
      ) : (
        posts.map((post) => (
          <article class="post-card">
            <h2>
              <a href={`/blog/${post.data.slug ?? post.id}`}>{post.data.title}</a>
            </h2>
            <div class="post-meta">
              <time datetime={post.data.date.toISOString().split('T')[0]}>
                {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <a class="post-category" href={`/blog/category/${post.data.category}/`}>
                {getCategoryLabel(post.data.category)}
              </a>
            </div>
            <p class="post-description">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((tag) => <a class="tag" href={`/blog/tag/${tag}/`}>{tag}</a>)}
              </div>
            )}
          </article>
        ))
      )}
    </div>
  </main>
</Layout>
