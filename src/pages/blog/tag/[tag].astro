---
import Layout from '../../../layouts/Base.astro';
import { getCategoryLabel } from '../../../lib/category';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      allTags.add(tag);
    }
  }
  return [...allTags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params as { tag: string };
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.tags.includes(tag)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={`标签：${tag} — 博客`} description={`「${tag}」标签下的所有文章。`}>
  <main class="blog-content" style="max-width: var(--content-width); margin: 2rem auto; padding: 0 var(--content-padding);">
    <h1>标签：{tag}</h1>
    <p><a href="/blog/" class="back-link">← 返回博客列表</a></p>

    <div class="post-list" style="margin-top: var(--space-lg);">
      {posts.length === 0 ? (
        <p>该标签下还没有文章。</p>
      ) : (
        posts.map((post) => (
          <article class="post-card">
            <h2>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
            <div class="post-meta">
              <time datetime={post.data.date.toISOString().split('T')[0]}>
                {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <a class="post-category" href={`/blog/category/${post.data.category}/`}>
                {getCategoryLabel(post.data.category)}
              </a>
            </div>
            <p class="post-description">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((t) => <a class="tag" href={`/blog/tag/${t}/`}>{t}</a>)}
              </div>
            )}
          </article>
        ))
      )}
    </div>
  </main>
</Layout>
